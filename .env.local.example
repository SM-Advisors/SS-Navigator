# SS Navigator — Local Development Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!

# Supabase (get from your Supabase project settings > API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Note: ANTHROPIC_API_KEY is set as a Supabase Edge Function secret, NOT here.
# Set it with: supabase secrets set ANTHROPIC_API_KEY=your_key_here
